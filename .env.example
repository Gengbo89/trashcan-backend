APP_NAME=trashcan-backend
APP_ENV=production
CORS_ORIGINS=*

# WeChat login and permissions.
WECHAT_APPID=change-me
WECHAT_SECRET=change-me
WECHAT_MESSAGE_TEMPLATE_ID=yrnDr2o4chCcJTxEcZm59BThRMrZ3rkt4oXZlHzakus
JWT_SECRET=change-me-long-random-string
ADMIN_OPENIDS=
DATABASE_URL=postgresql://trashcan:trashcan@postgres:5432/trashcan

# Alibaba Cloud Model Studio / DashScope.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_COMPATIBLE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_CHAT_MODELS=qwen-turbo,qwen-plus,qwen-long
AI_VISION_MODELS=wanx2.1-t2i-turbo:textToImage,wanx2.1-imageedit:imageToImage
AI_TRANSCRIPTION_MODELS=paraformer-v2
AI_IMAGE_SIZE=1024*1024

# RustFS/S3-compatible object storage.
RUSTFS_ENDPOINT_URL=https://rustfs.gengbo.top
RUSTFS_ACCESS_KEY=change-me
RUSTFS_SECRET_KEY=change-me
RUSTFS_BUCKET=change-me
RUSTFS_REGION=us-east-1
RUSTFS_ADDRESSING_STYLE=path

# Upload policy.
MAX_UPLOAD_SIZE_BYTES=10485760
DEFAULT_UPLOAD_DIR=
PRESIGNED_URL_EXPIRES_SECONDS=3600
